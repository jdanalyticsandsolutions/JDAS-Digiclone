"""
JDAS Dataverse Connector
========================
Handles reading and writing to Microsoft Dataverse.
Used by the FastAPI endpoints to persist and retrieve business data.

Prerequisites:
  pip install msal requests

Setup:
  1. Register an app in Azure AD
  2. Grant it Dynamics CRM user_impersonation permission
  3. Add credentials to environment variables (never hardcode)
  4. Replace YOUR_ORG in DATAVERSE_CONFIG
"""

import os
import json
import logging
from typing import Optional, Dict, Any, List
from datetime import datetime

try:
    import msal
    import requests
    DATAVERSE_AVAILABLE = True
except ImportError:
    DATAVERSE_AVAILABLE = False
    logging.warning("msal/requests not installed. Dataverse connector running in mock mode.")

logger = logging.getLogger(__name__)


# ─── CONFIG (from env vars — never hardcode secrets) ─────────────────────────

TENANT_ID     = os.getenv("DATAVERSE_TENANT_ID", "")
CLIENT_ID     = os.getenv("DATAVERSE_CLIENT_ID", "")
CLIENT_SECRET = os.getenv("DATAVERSE_CLIENT_SECRET", "")
ORG_URL       = os.getenv("DATAVERSE_ORG_URL", "https://YOUR_ORG.crm.dynamics.com")
API_BASE      = f"{ORG_URL}/api/data/v9.2/"
SCOPE         = [f"{ORG_URL}/.default"]


# ─── AUTH ─────────────────────────────────────────────────────────────────────

def get_access_token() -> Optional[str]:
    """Get OAuth2 token from Azure AD using client credentials flow."""
    if not DATAVERSE_AVAILABLE:
        return None
    if not all([TENANT_ID, CLIENT_ID, CLIENT_SECRET]):
        logger.warning("Dataverse credentials not configured. Set environment variables.")
        return None
    try:
        app = msal.ConfidentialClientApplication(
            CLIENT_ID,
            authority=f"https://login.microsoftonline.com/{TENANT_ID}",
            client_credential=CLIENT_SECRET,
        )
        result = app.acquire_token_for_client(scopes=SCOPE)
        if "access_token" in result:
            return result["access_token"]
        logger.error(f"Token error: {result.get('error_description')}")
        return None
    except Exception as e:
        logger.error(f"Auth error: {e}")
        return None


def get_headers() -> Dict[str, str]:
    token = get_access_token()
    return {
        "Authorization": f"Bearer {token}" if token else "",
        "OData-MaxVersion": "4.0",
        "OData-Version": "4.0",
        "Content-Type": "application/json",
        "Accept": "application/json",
        "Prefer": "return=representation",
    }


# ─── CRUD HELPERS ─────────────────────────────────────────────────────────────

def dv_get(entity: str, query: str = "") -> Optional[List[Dict]]:
    """GET records from a Dataverse table."""
    if not DATAVERSE_AVAILABLE:
        return None
    try:
        url = f"{API_BASE}{entity}{query}"
        resp = requests.get(url, headers=get_headers(), timeout=15)
        resp.raise_for_status()
        return resp.json().get("value", [])
    except Exception as e:
        logger.error(f"Dataverse GET {entity}: {e}")
        return None


def dv_post(entity: str, data: Dict) -> Optional[Dict]:
    """POST (create) a record in Dataverse."""
    if not DATAVERSE_AVAILABLE:
        logger.info(f"[MOCK] Would POST to {entity}: {list(data.keys())}")
        return {"jdas_id": "mock-id", **data}
    try:
        url = f"{API_BASE}{entity}"
        resp = requests.post(url, headers=get_headers(), json=data, timeout=15)
        resp.raise_for_status()
        return resp.json()
    except Exception as e:
        logger.error(f"Dataverse POST {entity}: {e}")
        return None


def dv_patch(entity: str, record_id: str, data: Dict) -> bool:
    """PATCH (update) a record in Dataverse."""
    if not DATAVERSE_AVAILABLE:
        logger.info(f"[MOCK] Would PATCH {entity}({record_id})")
        return True
    try:
        url = f"{API_BASE}{entity}({record_id})"
        resp = requests.patch(url, headers=get_headers(), json=data, timeout=15)
        resp.raise_for_status()
        return True
    except Exception as e:
        logger.error(f"Dataverse PATCH {entity}({record_id}): {e}")
        return False


# ─── DOMAIN OPERATIONS ────────────────────────────────────────────────────────

def get_active_inputs() -> Optional[Dict]:
    """
    Fetch the current active business inputs from Dataverse.
    Returns the most recently active input set.
    """
    records = dv_get(
        "jdas_business_inputses",
        "?$filter=jdas_is_active eq true&$orderby=jdas_effective_date desc&$top=1"
    )
    if records:
        return records[0]
    return None


def save_snapshot(snapshot_data: Dict) -> Optional[Dict]:
    """
    Persist a weekly snapshot to Dataverse.
    Called automatically by the /snapshot and /dashboard endpoints.
    """
    record = {
        "jdas_week_start":          snapshot_data["meta"]["week_of"],
        "jdas_created_at":          snapshot_data["meta"]["generated_at"],
        "jdas_cash_on_hand":        snapshot_data["cash"]["amount"],
        "jdas_weekly_burn":         snapshot_data["cash"]["weekly_out"],
        "jdas_weekly_in":           snapshot_data["cash"]["weekly_in"],
        "jdas_net_cash_12w":        snapshot_data["cash"]["net_12w"],
        "jdas_ending_cash_12w":     snapshot_data["cash"]["ending_cash"],
        "jdas_cash_status":         snapshot_data["cash"]["status"],
        "jdas_tax_reserve_12w":     snapshot_data["cash"]["tax_reserve_12w"],
        "jdas_active_workload_hrs": snapshot_data["workload"]["active_hrs"],
        "jdas_sustainable_cap_wk":  snapshot_data["workload"]["sustainable_cap"],
        "jdas_backlog_hrs":         snapshot_data["workload"]["backlog_hrs"],
        "jdas_delay_days":          snapshot_data["workload"]["wait_days"],
        "jdas_capacity_stress":     snapshot_data["workload"]["stress_score"],
        "jdas_workload_status":     snapshot_data["workload"]["status"],
        "jdas_leads_per_week":      snapshot_data["pipeline"]["leads_per_week"],
        "jdas_qualified_per_week":  snapshot_data["pipeline"]["qualified_per_week"],
        "jdas_win_rate":            snapshot_data["pipeline"]["win_rate"],
        "jdas_avg_project_value":   snapshot_data["pipeline"]["avg_project_value"],
        "jdas_revenue_12w":         snapshot_data["pipeline"]["revenue_12w"],
        "jdas_cash_collected_12w":  snapshot_data["pipeline"]["cash_collected_12w"],
        "jdas_quality_score":       snapshot_data["quality"]["score"],
        "jdas_quality_label":       snapshot_data["quality"]["label"],
        "jdas_rework_rate":         snapshot_data["quality"]["rework_rate"],
        "jdas_retention_likelihood":snapshot_data["quality"]["retention_likelihood"],
        "jdas_referral_likelihood": snapshot_data["quality"]["referral_likelihood"],
        "jdas_churn_risk":          snapshot_data["quality"]["churn_risk"],
        "jdas_mrr":                 snapshot_data["recurring"]["mrr"],
        "jdas_mrr_month12":         snapshot_data["recurring"]["mrr_month12"],
        "jdas_mrr_stability":       snapshot_data["recurring"]["stability_score"],
        "jdas_retainer_clients":    snapshot_data["recurring"]["retainer_clients"],
        "jdas_mrr_churn_flag":      snapshot_data["recurring"]["churn_flag"],
        "jdas_team_capacity_wk":    snapshot_data["labor"]["team_capacity_wk"],
        "jdas_labor_cost_monthly":  snapshot_data["labor"]["labor_cost_monthly"],
        "jdas_gross_labor_margin":  snapshot_data["labor"]["gross_margin"],
        "jdas_hire_trigger":        snapshot_data["labor"]["num_subs"],
        "jdas_xp_score":            snapshot_data["score"]["xp"],
        "jdas_xp_level":            snapshot_data["score"]["level"],
        "jdas_xp_title":            snapshot_data["score"]["title"],
    }
    return dv_post("jdas_business_snapshots", record)


def save_inputs(inputs_data: Dict) -> Optional[Dict]:
    """
    Save updated business inputs to Dataverse.
    Marks all previous inputs as inactive first.
    """
    # Deactivate old inputs
    old = dv_get("jdas_business_inputses", "?$filter=jdas_is_active eq true")
    if old:
        for rec in old:
            dv_patch("jdas_business_inputses", rec["jdas_inputsid"], {"jdas_is_active": False})

    record = {
        "jdas_effective_date": datetime.utcnow().isoformat() + "Z",
        "jdas_is_active": True,
        **{f"jdas_{k}": v for k, v in inputs_data.items() if v is not None}
    }
    return dv_post("jdas_business_inputses", record)


def get_snapshot_history(weeks: int = 12) -> Optional[List[Dict]]:
    """Fetch the last N weekly snapshots for trend charts."""
    return dv_get(
        "jdas_business_snapshots",
        f"?$orderby=jdas_week_start desc&$top={weeks}"
        "&$select=jdas_week_start,jdas_cash_on_hand,jdas_xp_score,"
        "jdas_backlog_hrs,jdas_win_rate,jdas_mrr,jdas_quality_score"
    )


def upsert_project(project: Dict) -> Optional[Dict]:
    """Create or update an active project record."""
    existing = dv_get(
        "jdas_active_projectses",
        f"?$filter=jdas_project_code eq '{project.get('code', '')}'"
    )
    if existing:
        dv_patch("jdas_active_projectses", existing[0]["jdas_projectid"],
                 {f"jdas_{k}": v for k, v in project.items()})
        return existing[0]
    return dv_post("jdas_active_projectses",
                   {f"jdas_{k}": v for k, v in project.items()})
